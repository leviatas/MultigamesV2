#!/usr/bin/env python3
"""
Pre-commit hook para detectar secretos (wrapper version)
Puede ser ejecutado directamente por Git en cualquier plataforma.
"""

import sys
import subprocess
from pathlib import Path

def main():
    # Obtener la raíz del repositorio
    try:
        result = subprocess.run(
            ['git', 'rev-parse', '--show-toplevel'],
            capture_output=True,
            text=True,
            check=True
        )
        repo_root = Path(result.stdout.strip())
    except Exception as e:
        print(f"❌ Error al obtener la raíz del repositorio: {e}", file=sys.stderr)
        return 1
    
    validate_script = repo_root / 'scripts' / 'validate-secrets.py'
    
    if not validate_script.exists():
        print(f"❌ Error: No se encontró el script de validación en {validate_script}", file=sys.stderr)
        return 1
    
    # Ejecutar el script de validación
    try:
        result = subprocess.run(
            [sys.executable, str(validate_script)],
            cwd=repo_root
        )
        return result.returncode
    except Exception as e:
        print(f"❌ Error al ejecutar el validador: {e}", file=sys.stderr)
        return 1

if __name__ == '__main__':
    sys.exit(main())
